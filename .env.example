# Twilio Credentials
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# OpenAI/OpenRouter API
API_KEY=your_openrouter_api_key
API_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=meta-llama/llama-3.3-70b-instruct:free

# EmailJS Configuration (for email notifications)
EMAILJS_SERVICE_ID=service_abc123
EMAILJS_TEMPLATE_ID=template_xyz789
EMAILJS_PUBLIC_KEY=user_abc123xyz
EMAILJS_PRIVATE_KEY=pk_abc123xyz
OWNER_EMAIL=your-email@gmail.com

# Server URL (update this after deploying)
SERVER_URL=https://your-server-url.com

# Shared secret between missed-call-detector and server (protects /missed-call)
MISSED_CALL_SECRET=some-long-random-string

# For missed-call-detector.js (Termux phone side)
OWNER_NUMBER=+91XXXXXXXXXX
